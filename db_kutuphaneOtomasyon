CREATE DATABASE Kutuphane
use KutuphaneIKI;

CREATE TABLE Adresler(
adresNo INT PRIMARY KEY NOT NULL,
sehir NVARCHAR(50) NOT NULL,
mahalle NVARCHAR(50),
binaNo INT,
postaKodu INT,
ulke NVARCHAR(50),
cadde NVARCHAR(50)
);

create table Uyeler(
uyeNo int Primary Key not null identity(1,1),
uyeAdi nvarchar (50) not null,
uyeSoyadi nvarchar (50) not null,
cinsiyet char (2),
telefon nvarchar (50),
eposta nvarchar(50),
);

ALTER TABLE Uyeler 
ADD adresNo INT
CONSTRAINT "uyeler_adresler"
FOREIGN 
KEY(adresNo) REFERENCES Adresler(adresNo);

CREATE TABLE Kutuphane(
kutuphaneNo int PRIMARY KEY NOT NULL IDENTITY(1,1),
kutuphaneAdi NVARCHAR(50) NOT NULL,
aciklama NVARCHAR (50),
adresNo INT FOREIGN KEY(adresNo) REFERENCES Adresler(adresNo)
);

CREATE TABLE Kitaplar(
ISBN NVARCHAR(50) PRIMARY KEY NOT NULL,
kitapAdi NVARCHAR(255) NOT NULL,
sayfaSayisi INT,
yayinTarihi DATE
);

CREATE TABLE Emanet(
emanetNo INT PRIMARY KEY NOT NULL IDENTITY(1,1),
uyeNo INT FOREIGN KEY(uyeNo) REFERENCES Uyeler(uyeNo),
ISBN NVARCHAR(50) FOREIGN KEY(ISBN) REFERENCES Kitaplar(ISBN), 
emanetTarihi DATETIME,
teslimTarihi DATETIME,
);

CREATE TABLE Kategoriler(
kategoriNo INT PRIMARY KEY,
kategoriAdi NVARCHAR (50) NOT NULL,
);

CREATE TABLE Yazarlar(
yazarNo INT PRIMARY KEY NOT NULL,
yazarAdi NVARCHAR(50) NOT NULL,
yazarSoyadi NVARCHAR(20) NOT NULL,
);

CREATE TABLE KitapYazar(
ID INT PRIMARY KEY IDENTITY(1,1) NOT NULL,
ISBN NVARCHAR(50) FOREIGN KEY(ISBN) REFERENCES Kitaplar(ISBN) NOT NULL,
yazarNo INT FOREIGN KEY(yazarNo) REFERENCES Yazarlar(yazarNo) NOT NULL,
);

CREATE TABLE KitapKutuphane(
ID INT PRIMARY KEY IDENTITY(1,1) NOT NULL,
miktar INT NOT NULL,
ISBN NVARCHAR(50) FOREIGN KEY(ISBN) REFERENCES Kitaplar(ISBN),
kutuphaneNo INT FOREIGN KEY (kutuphaneNo) REFERENCES Kutuphane(KutuphaneNo) NOT NULL
);
