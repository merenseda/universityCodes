-- ------------------------------------------------------------
-- TABLO OLUŞTURMA
-- ------------------------------------------------------------

CREATE TABLE Musteri (
    Mno      INT PRIMARY KEY,
    Madi     VARCHAR(50),
    Msoyadi  VARCHAR(50),
    Madres   VARCHAR(100),
    Mtelefon VARCHAR(20)
);

CREATE TABLE Arac (
    Aracno INT PRIMARY KEY,
    Model  INT,
    Marka  VARCHAR(50),
    Plaka  VARCHAR(20),
    Fiyat  DECIMAL(10, 2)
);

CREATE TABLE Satis (
    Satno     INT PRIMARY KEY,
    Mno       INT,
    Aracno    INT,
    Sat_tarih DATE,
    Sfiyat    DECIMAL(10, 2),
    FOREIGN KEY (Mno)    REFERENCES Musteri(Mno),
    FOREIGN KEY (Aracno) REFERENCES Arac(Aracno)
);

CREATE TABLE Alim (
    Alimno     INT PRIMARY KEY,
    Mno        INT,
    Aracno     INT,
    Alim_tarih DATE,
    Afiyat     DECIMAL(10, 2),
    FOREIGN KEY (Mno)    REFERENCES Musteri(Mno),
    FOREIGN KEY (Aracno) REFERENCES Arac(Aracno)
);


