-- ------------------------------------------------------------
-- SORGULAR
-- ------------------------------------------------------------

-- 1. Satış yapılan müşterilerin isimlerini listele
SELECT DISTINCT Musteri.Madi, Musteri.Msoyadi
FROM Musteri
INNER JOIN Satis ON Musteri.Mno = Satis.Mno;


-- 2. Hangi müşteriden hangi aracın alındığını listele
SELECT Musteri.Madi, Musteri.Msoyadi, Arac.Marka, Arac.Model
FROM Alim
INNER JOIN Musteri ON Alim.Mno = Musteri.Mno
INNER JOIN Arac ON Alim.Aracno = Arac.Aracno;


-- 3. Her bir müşteriden alınan araçların sayısını listele
SELECT Musteri.Madi, Musteri.Msoyadi, COUNT(Alim.Alimno) AS AracSayisi
FROM Alim
INNER JOIN Musteri ON Alim.Mno = Musteri.Mno
GROUP BY Musteri.Mno, Musteri.Madi, Musteri.Msoyadi;


-- 4. Satılan araçların marka ve modelini bul
SELECT Arac.Marka, Arac.Model
FROM Satis
INNER JOIN Arac ON Satis.Aracno = Arac.Aracno;


-- 5. Toplam satış ve toplam alım tutarları ile farkını bul
SELECT
    SUM(Satis.Sfiyat)                      AS ToplamSatis,
    SUM(Alim.Afiyat)                       AS ToplamAlim,
    SUM(Alim.Afiyat) - SUM(Satis.Sfiyat)  AS Fark
FROM Satis, Alim;


-- 6. Hiç satışı yapılmamış araçları listele
SELECT Arac.Aracno, Arac.Marka, Arac.Model
FROM Arac
WHERE Arac.Aracno NOT IN (SELECT Satis.Aracno FROM Satis);


-- 7. Her aracın ortalama satış tutarını bul
SELECT Arac.Marka, Arac.Model, AVG(Satis.Sfiyat) AS OrtSatisFiyati
FROM Satis
INNER JOIN Arac ON Satis.Aracno = Arac.Aracno
GROUP BY Arac.Aracno, Arac.Marka, Arac.Model;


-- 8. Alımı ve satışı yapılan tüm araçların marka, model ve alım-satış sayısını listele
SELECT
    Arac.Marka,
    Arac.Model,
    COUNT(DISTINCT Alim.Alimno) AS AlimSayisi,
    COUNT(DISTINCT Satis.Satno) AS SatisSayisi
FROM Arac
INNER JOIN Alim  ON Arac.Aracno = Alim.Aracno
INNER JOIN Satis ON Arac.Aracno = Satis.Aracno
GROUP BY Arac.Aracno, Arac.Marka, Arac.Model;


-- 9. 20000'den fazla tutara satılan araçları kimlerin hangi aracı aldığını bul
SELECT Musteri.Madi, Musteri.Msoyadi, Arac.Marka, Arac.Model, Satis.Sfiyat
FROM Satis
INNER JOIN Musteri ON Satis.Mno = Musteri.Mno
INNER JOIN Arac    ON Satis.Aracno = Arac.Aracno
WHERE Satis.Sfiyat > 20000;


-- 10. Tokatta bulunan müşterilere satışı yapılan araçları listele
SELECT Musteri.Madi, Musteri.Msoyadi, Arac.Marka, Arac.Model
FROM Satis
INNER JOIN Musteri ON Satis.Mno = Musteri.Mno
INNER JOIN Arac    ON Satis.Aracno = Arac.Aracno
WHERE Musteri.Madres LIKE '%Tokat%';
